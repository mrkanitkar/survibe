    "Opens iOS Settings to enable microphone access": {
      "comment": "A hint that appears when hovering over the \"Open Settings\" button in the PracticeTab.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफ़ोन एक्सेस सक्षम करने के लिए iOS सेटिंग्स खोलता है"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಮೈಕ್ರೋಫೋನ್ ಪ್ರವೇಶ ಸಕ್ರಿಯಗೊಳಿಸಲು iOS ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ತೆರೆಯುತ್ತದೆ"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "മൈക്രോഫോൺ ആക്‌സസ് പ്രവർത്തനക്ഷമമാക്കാൻ iOS സെറ്റിംഗ്സ് തുറക്കുന്നു"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மைக்ரோஃபோன் அணுகலை இயக்க iOS அமைப்புகளைத் திறக்கும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మైక్రోఫోన్ యాక్సెస్ ప్రారంభించడానికి iOS సెట్టింగ్‌లను తెరుస్తుంది"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "मायक्रोफोन परवानगी सक्षम करण्यासाठी iOS सेटिंग्ज उघडते"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "মাইক্রোফোন অনুমতি সক্ষম করতে iOS সেটিংস খোলে"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "માઇક્રોફોન પરવાનગી સક્ષમ કરવા iOS સેટિંગ્સ ખોલે છે"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਮਾਈਕ੍ਰੋਫ਼ੋਨ ਇਜਾਜ਼ਤ ਚਾਲੂ ਕਰਨ ਲਈ iOS ਸੈਟਿੰਗਾਂ ਖੋਲ੍ਹਦਾ ਹੈ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مائیکروفون اجازت فعال کرنے کے لیے iOS سیٹنگز کھولتا ہے"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफोन अनुमति सक्षम गर्न iOS सेटिङ्स खोल्छ"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "মাইক্ৰ'ফোন অনুমতি সক্ষম কৰিবলৈ iOS ছেটিংছ খোলে"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ମାଇକ୍ରୋଫୋନ୍ ଅନୁମତି ସକ୍ଷମ କରିବାକୁ iOS ସେଟିଂସ୍ ଖୋଲେ"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "मायक्रोफोन परवानगी चालू करूंक iOS सेटिंग्ज उगडता"
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफोन अनुमति सक्षम करबाक लेल iOS सेटिंग्स खोलैत अछि"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "ध्वनिग्राहक-अनुज्ञां सक्रियं कर्तुं iOS विन्यासं उद्घाटयति"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रफन अनुमति होनो iOS सेटिंस खोलो"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफोन इजाजत चालू करने आस्तै iOS सेटिंग्ज खोलदा ऐ"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "مایکروفون اِجازَت چالوٗ کَرنہٕ خاطرِ iOS سیٹِنگز کھولِ"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "মাইক্রোফোন অনুমতি শেম্গৎনবগীদমক iOS সেটিংস হাংদোকই"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱢᱟᱭᱠᱨᱳᱯᱷᱚᱱ ᱟᱱᱩᱢᱚᱛᱤ ᱪᱟᱞᱩ ᱞᱟᱹᱜᱤᱫ iOS ᱥᱮᱴᱤᱝ ᱡᱷᱤᱡ ᱮᱫᱟ"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "مائڪروفون اجازت فعال ڪرڻ لاءِ iOS سيٽنگز کولي ٿو"
          }
        }
      }
