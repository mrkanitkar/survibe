    "Choose between melody, chord, or both detection modes": {
      "comment": "A hint that explains the purpose of the picker in the Practice tab.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मेलोडी, कॉर्ड, या दोनों डिटेक्शन मोड में से चुनें"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಮೆಲೊಡಿ, ಕಾರ್ಡ್, ಅಥವಾ ಎರಡೂ ಡಿಟೆಕ್ಷನ್ ಮೋಡ್‌ಗಳಲ್ಲಿ ಆಯ್ಕೆಮಾಡಿ"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "മെലഡി, കോർഡ്, അല്ലെങ്കിൽ രണ്ടും ഡിറ്റക്ഷൻ മോഡുകളിൽ നിന്ന് തിരഞ്ഞെടുക്കുക"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மெலடி, கார்ட், அல்லது இரண்டும் கண்டறிதல் முறைகளிலிருந்து தேர்ந்தெடுக்கவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మెలడీ, కార్డ్, లేదా రెండూ డిటెక్షన్ మోడ్‌లలో ఎంచుకోండి"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "मेलडी, कॉर्ड, किंवा दोन्ही ओळख पद्धतींमधून निवडा"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "মেলডি, কর্ড, বা উভয় শনাক্তকরণ মোড থেকে বেছে নিন"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "મેલોડી, કોર્ડ, અથવા બંને ડિટેક્શન મોડમાંથી પસંદ કરો"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਮੈਲੋਡੀ, ਕੌਰਡ, ਜਾਂ ਦੋਵੇਂ ਖੋਜ ਮੋਡਾਂ ਵਿੱਚੋਂ ਚੁਣੋ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "میلوڈی، کارڈ، یا دونوں ڈیٹیکشن موڈز میں سے چنیں"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "मेलोडी, कर्ड, वा दुवै पहिचान मोडबाट छान्नुहोस्"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "মেলডি, কৰ্ড, বা দুয়োটা চিনাক্তকৰণ মোডৰ পৰা বাছনি কৰক"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ମେଲୋଡି, କର୍ଡ, କିମ୍ବା ଉଭୟ ଚିହ୍ନଟ ମୋଡରୁ ବାଛନ୍ତୁ"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "मेलोडी, कॉर्ड, वा दोनूय ओळख पद्दतींतल्यान निवडात"
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "मेलोडी, कॉर्ड, या दुनू पहचान मोडमे सँ चुनू"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वरसङ्गति, कॉर्ड, वा उभयं पहचान-विधिषु चिनुत"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "मेलडी, कर्ड, एबा मोननैबो सिनायथि मोडनिफ्राय सायख"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "मेलोडी, कॉर्ड, या दोये पछान मोडें चा चुनो"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "مَیلوٗڈی، کارڈ، یا دۆشوٗنی پَتاہ موڈَن مَنٛز چُنِو"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "মেলদি, কোর্ড, নত্রগা অনীমখ খংদোকপা মোদতগী খনবীরকউ"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱢᱮᱞᱳᱰᱤ, ᱠᱳᱨᱰ, ᱟᱨ ᱵᱟᱨᱭᱟ ᱢᱤᱫ ᱪᱤᱱᱦᱟᱹ ᱢᱳᱰ ᱠᱷᱚᱱ ᱵᱟᱪᱷᱟᱣ ᱢᱮ"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "ميلوڊي، ڪارڊ، يا ٻئي ڳولا موڊن مان چونڊيو"
          }
        }
      }
    },
    "Choose detection speed: fast, balanced, or precise": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिटेक्शन स्पीड चुनें: तेज़, संतुलित, या सटीक"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಡಿಟೆಕ್ಷನ್ ವೇಗ ಆಯ್ಕೆಮಾಡಿ: ವೇಗ, ಸಮತೋಲಿತ, ಅಥವಾ ನಿಖರ"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഡിറ്റക്ഷൻ വേഗത തിരഞ്ഞെടുക്കുക: വേഗം, സന്തുലിതം, അല്ലെങ്കിൽ കൃത്യം"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கண்டறிதல் வேகத்தைத் தேர்ந்தெடுக்கவும்: வேகம், சமநிலை, அல்லது துல்லியம்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "డిటెక్షన్ వేగాన్ని ఎంచుకోండి: వేగం, సమతుల్యం, లేదా ఖచ్చితం"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "ओळख गती निवडा: जलद, संतुलित, किंवा अचूक"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শনাক্তকরণ গতি বেছে নিন: দ্রুত, ভারসাম্যপূর্ণ, বা নির্ভুল"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "ડિટેક્શન ઝડપ પસંદ કરો: ઝડપી, સંતુલિત, અથવા ચોક્કસ"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਖੋਜ ਦੀ ਗਤੀ ਚੁਣੋ: ਤੇਜ਼, ਸੰਤੁਲਿਤ, ਜਾਂ ਸਟੀਕ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ڈیٹیکشن رفتار چنیں: تیز، متوازن، یا درست"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "पहिचान गति छान्नुहोस्: छिटो, सन्तुलित, वा सटीक"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "চিনাক্তকৰণ গতি বাছনি কৰক: দ্ৰুত, সন্তুলিত, বা সঠিক"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ଚିହ୍ନଟ ଗତି ବାଛନ୍ତୁ: ଦ୍ରୁତ, ସନ୍ତୁଳିତ, କିମ୍ବା ସଠିକ୍"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "ओळख वेग निवडात: वेगान, संतुलीत, वा अचूक"
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "पहचान गति चुनू: तेज, संतुलित, या सटीक"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "पहचान-वेगं चिनुत: द्रुतम्, सन्तुलितम्, वा सूक्ष्मम्"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "सिनायथि गोबां सायख: गोख्रों, सम, एबा गेजेर"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "पछान दी गति चुनो: तेज, संतुलित, या सटीक"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "پَتاہ رَفتار چُنِو: تیٖز، مُتوازِن، یا دُرُست"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "খংদোকপা চপ খনবীরকউ: চপ, মীৎয়েং, নত্রগা অচুম্বা"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱪᱤᱱᱦᱟᱹ ᱞᱮᱠᱟ ᱵᱟᱪᱷᱟᱣ ᱢᱮ: ᱦᱩᱭᱩᱜ, ᱵᱟᱨᱟᱵᱟᱨ, ᱟᱨ ᱥᱟᱦᱤ"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "ڳولا جي رفتار چونڊيو: تيز، متوازن، يا صحيح"
          }
        }
      }
    },
