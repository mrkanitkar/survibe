{
  "sourceLanguage" : "en",
  "strings" : {
    "—" : {
      "comment" : "A separator between the Western and Swar note names in the active note label.",
      "isCommentAutoGenerated" : true
    },
    "%" : {
      "comment" : "A unit of measurement for percentage.",
      "isCommentAutoGenerated" : true
    },
    "%@ %lld, %@" : {
      "comment" : "A combined label for a note displayed in the Practice tab. The first part shows the Western name and octave of the note, separated by a space. The second part provides the equivalent name in the Indian (Swar) musical system, also separated by a space.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld, %3$@"
          }
        }
      }
    },
    "%@ by %@" : {
      "comment" : "A single label that combines the song title and artist name.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ by %2$@"
          }
        }
      }
    },
    "%@ by %@, difficulty %lld of 5" : {
      "comment" : "A combined label for a song's title, artist, and difficulty level, suitable for use as an accessibility label. The first and second arguments are the song's title and artist, respectively. The argument is the song's difficulty level, formatted as a number from 1 to 5.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ by %2$@, difficulty %3$lld of 5"
          }
        }
      }
    },
    "%@ grade" : {
      "comment" : "An accessibility label for a note cell that includes the score achieved for that note.",
      "isCommentAutoGenerated" : true
    },
    "%@ visualization" : {
      "comment" : "The title of the current audio visualization mode.",
      "isCommentAutoGenerated" : true
    },
    "%@ warning: %@" : {
      "comment" : "An accessibility label that combines the severity and message of a warning. The first argument is the capitalized string representation of the warning's severity. The second argument is the warning's message.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
