    "Could not access microphone. Please check permissions and try again." : {
      "localizations" : {
        "as" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "মাইক্ৰ'ফোন ব্যৱহাৰ কৰিব পৰা নগ'ল। অনুগ্ৰহ কৰি অনুমতি পৰীক্ষা কৰক আৰু পুনৰ চেষ্টা কৰক।"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "মাইক্রোফোন ব্যবহার করা যায়নি। অনুগ্রহ করে অনুমতি পরীক্ষা করে আবার চেষ্টা করুন।"
          }
        },
        "brx" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माइक्रफन बाहायनो हायाखै। अनुमतिफोर नायबिलाय आरो फिन नाजा।"
          }
        },
        "doi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माइक्रोफोन इस्तेमाल नेईं होई सकेआ। कृपया इजाजतां जाँचो ते फी कोशिश करो।"
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "માઇક્રોફોન વાપરી શકાયો નહીં. કૃપા કરીને પરવાનગીઓ તપાસો અને ફરી પ્રયાસ કરો."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माइक्रोफ़ोन एक्सेस नहीं हो सका। कृपया अनुमतियां जांचें और पुनः प्रयास करें।"
          }
        },
        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ಮೈಕ್ರೋಫೋನ್ ಪ್ರವೇಶಿಸಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ. ದಯವಿಟ್ಟು ಅನುಮತಿಗಳನ್ನು ಪರಿಶೀಲಿಸಿ ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ."
          }
        },
        "kok" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मायक्रोफोन वापरूंक जालें ना. उपकार करून परवानग्यो तपासात आनी परत यत्न करात."
          }
        },
        "ks" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مایکروفون اِستِعمال کَرنہٕ آو نَہ۔ مِہربٲنی کٔرِتھ اِجازَت چیک کرِو تہٕ بیٖیِ کوشِش کرِو۔"
          }
        },
        "mai" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माइक्रोफोन उपयोग नहि भेल। कृपया अनुमति जाँचू आ फेर प्रयास करू।"
          }
        },
        "ml" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "മൈക്രോഫോൺ ആക്‌സസ് ചെയ്യാൻ കഴിഞ്ഞില്ല. ദയവായി അനുമതികൾ പരിശോധിച്ച് വീണ്ടും ശ്രമിക്കുക."
          }
        },
        "mni" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "মাইক্রোফোন শীজিন্নবা ঙমদে। চহী অনুমতিশীং য়েংবীরকউ অমসুং অমুক হোৎনবীরকউ।"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मायक्रोफोन वापरता आला नाही. कृपया परवानग्या तपासा आणि पुन्हा प्रयत्न करा."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माइक्रोफोन प्रयोग गर्न सकिएन। कृपया अनुमतिहरू जाँच गर्नुहोस् र पुन: प्रयास गर्नुहोस्।"
          }
        },
        "or" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ମାଇକ୍ରୋଫୋନ୍ ବ୍ୟବହାର କରିହେଲା ନାହିଁ। ଦୟାକରି ଅନୁମତି ଯାଞ୍ଚ କରନ୍ତୁ ଏବଂ ପୁନଃ ଚେଷ୍ଟା କରନ୍ତୁ।"
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਮਾਈਕ੍ਰੋਫ਼ੋਨ ਵਰਤਿਆ ਨਹੀਂ ਜਾ ਸਕਿਆ। ਕਿਰਪਾ ਕਰਕੇ ਇਜਾਜ਼ਤਾਂ ਜਾਂਚੋ ਅਤੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"
          }
        },
        "sa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ध्वनिग्राहकं प्रयोक्तुं न शक्यम्। कृपया अनुज्ञाः परीक्ष्य पुनः प्रयतताम्।"
          }
        },
        "sat" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ᱢᱟᱭᱠᱨᱳᱯᱷᱚᱱ ᱵᱮᱵᱷᱟᱨ ᱠᱟ ᱵᱟᱝ ᱫᱟᱲᱮᱭᱟᱜ᱾ ᱫᱟᱭᱟ ᱠᱟᱛᱮ ᱟᱱᱩᱢᱚᱛᱤ ᱧᱮᱞ ᱢᱮ ᱟᱨ ᱫᱩᱦᱲᱟᱹ ᱠᱩᱨᱩᱢᱩᱴᱩ ᱢᱮ᱾"
          }
        },
        "sd" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مائڪروفون استعمال نٿو ٿي سگهي. مهرباني ڪري اجازتون چيڪ ڪريو ۽ وري ڪوشش ڪريو."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "மைக்ரோஃபோனை அணுக இயலவில்லை. அனுமதிகளை சரிபார்த்து மீண்டும் முயற்சிக்கவும்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మైక్రోఫోన్‌ను యాక్సెస్ చేయడం సాధ్యం కాలేదు. దయచేసి అనుమతులను తనిఖీ చేసి మళ్ళీ ప్రయత్నించండి."
          }
