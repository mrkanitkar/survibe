        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "മൈക്രോഫോണിലൂടെ പിയാനോ സ്വരങ്ങൾ കേൾക്കാൻ തുടങ്ങുന്നു"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மைக்ரோஃபோன் வழியாக பியானோ சுரங்களைக் கேட்கத் தொடங்கும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మైక్రోఫోన్ ద్వారా పియానో స్వరాలను వినడం ప్రారంభిస్తుంది"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "मायक्रोफोनद्वारे पियानो स्वर ऐकणे सुरू करते"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "মাইক্রোফোনের মাধ্যমে পিয়ানো স্বর শোনা শুরু করে"
