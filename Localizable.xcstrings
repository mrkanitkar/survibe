        },
        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ಮೈಕ್ರೋಫೋನ್ ಮೂಲಕ ಪಿಯಾನೋ ಸ್ವರಗಳನ್ನು ಕೇಳಲು ಪ್ರಾರಂಭಿಸುತ್ತದೆ"
