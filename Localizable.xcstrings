        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "માઇક્રોફોન દ્વારા પિયાનો સ્વર સાંભળવાનું શરૂ કરે છે"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਮਾਈਕ੍ਰੋਫ਼ੋਨ ਰਾਹੀਂ ਪਿਆਨੋ ਸੁਰਾਂ ਸੁਣਨਾ ਸ਼ੁਰੂ ਕਰਦਾ ਹੈ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مائیکروفون سے پیانو سُر سننا شروع کرتا ہے"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफोनबाट पियानो स्वरहरू सुन्न सुरु गर्छ"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "মাইক্ৰ'ফোনৰ জৰিয়তে পিয়ানো স্বৰ শুনা আৰম্ভ কৰে"
