    "Current pitch expression detected from your playing": {
      "comment": "An accessibility hint explaining the purpose of the pitch expression badge in the PracticeTab view.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके वादन से पहचाना गया वर्तमान स्वर अभिव्यक्ति"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ನಿಮ್ಮ ನುಡಿಸುವಿಕೆಯಿಂದ ಗುರುತಿಸಲಾದ ಪ್ರಸ್ತುತ ಸ್ವರ ಅಭಿವ್ಯಕ್ತಿ"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "നിങ്ങളുടെ വായനയിൽ നിന്ന് കണ്ടെത്തിയ നിലവിലെ സ്വര ഭാവം"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் இசையிலிருந்து கண்டறியப்பட்ட தற்போதைய சுர வெளிப்பாடு"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ వాయిద్యం నుండి గుర్తించిన ప్రస్తుత స్వర వ్యక్తీకరణ"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमच्या वादनातून ओळखलेली सध्याची स्वर अभिव्यक्ती"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার বাজনা থেকে শনাক্ত করা বর্তমান স্বর অভিব্যক্তি"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "તમારા વાદનમાંથી શોધાયેલ હાલની સ્વર અભિવ્યક્તિ"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਤੁਹਾਡੇ ਵਜਾਉਣ ਤੋਂ ਖੋਜੀ ਮੌਜੂਦਾ ਸੁਰ ਅਭਿਵਿਅਕਤੀ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے بجانے سے پہچانا گیا موجودہ سُر اظہار"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "तपाईंको बजाइबाट पहिचान गरिएको हालको स्वर अभिव्यक्ति"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "আপোনাৰ বাদনৰ পৰা চিনাক্ত কৰা বৰ্তমান স্বৰ অভিব্যক্তি"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ଆପଣଙ୍କ ବାଦନରୁ ଚିହ୍ନଟ ହୋଇଥିବା ବର୍ତ୍ତମାନ ସ୍ୱର ଅଭିବ୍ୟକ୍ତି"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमच्या वादनांतल्यान ओळखिल्ली सद्याची स्वर अभिव्यक्ती"
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "अहाँक वादनसँ पहचानल गेल वर्तमान स्वर अभिव्यक्ति"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "भवतः वादनात् ज्ञातं वर्तमानं स्वराभिव्यक्तिः"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "नोंथांनि बादनजों सिनायथानाय दानि सुर बेखेव"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "तुसां दे बजाने चा पछानेआ गेआ मौजूदा सुर भाव"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "تُہنٛدِ بَجٲوَنہٕ پَتاہ لَگٲوُنہٕ موجوٗدہ سُر اِظہار"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "নহাক্কী থম্বালগী খংদোকপা তুংগীন্নবা স্বর পুক্নীং"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱟᱢᱟᱜ ᱵᱟᱡᱟᱣ ᱠᱷᱚᱱ ᱪᱤᱱᱦᱟᱹ ᱧᱟᱢᱟᱜ ᱱᱤᱛᱚᱜᱟᱜ ᱥᱩᱨ ᱵᱮᱵᱷᱟᱨ"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "توهان جي وجهائڻ مان ڳولهيل موجوده سُر اظهار"
          }
        }
      }
    },
