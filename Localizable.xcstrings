    "Microphone access is needed to detect notes.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नोट्स पहचानने के लिए माइक्रोफ़ोन एक्सेस आवश्यक है।"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸ್ವರಗಳನ್ನು ಗುರುತಿಸಲು ಮೈಕ್ರೋಫೋನ್ ಪ್ರವೇಶ ಅಗತ್ಯವಿದೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "സ്വരങ്ങൾ തിരിച്ചറിയാൻ മൈക്രോഫോൺ ആക്‌സസ് ആവശ്യമാണ്."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சுரங்களைக் கண்டறிய மைக்ரோஃபோன் அணுகல் தேவை."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "స్వరాలను గుర్తించడానికి మైక్రోఫోన్ యాక్సెస్ అవసరం."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर ओळखण्यासाठी मायक्रोफोन परवानगी आवश्यक आहे."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বর শনাক্ত করতে মাইক্রোফোন অনুমতি প্রয়োজন।"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "સ્વર શોધવા માટે માઇક્રોફોન પરવાનગી જરૂરી છે."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸੁਰਾਂ ਖੋਜਣ ਲਈ ਮਾਈਕ੍ਰੋਫ਼ੋਨ ਇਜਾਜ਼ਤ ਲੋੜੀਂਦੀ ਹੈ।"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سُر پہچاننے کے لیے مائیکروفون اجازت درکار ہے۔"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वरहरू पहिचान गर्न माइक्रोफोन अनुमति आवश्यक छ।"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বৰ চিনাক্ত কৰিবলৈ মাইক্ৰ'ফোন অনুমতি প্ৰয়োজন।"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ସ୍ୱର ଚିହ୍ନଟ କରିବାକୁ ମାଇକ୍ରୋଫୋନ୍ ଅନୁମତି ଆବଶ୍ୟକ।"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर ओळखूंक मायक्रोफोन परवानगी जाय."
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर पहचानबाक लेल माइक्रोफोन अनुमति आवश्यक अछि।"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वरान् ज्ञातुं ध्वनिग्राहक-अनुज्ञा आवश्यकी।"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "सुर सिनायनो माइक्रफन अनुमति गोनां।"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुर पछानने आस्तै माइक्रोफोन इजाजत जरूरी ऐ।"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "سُر پَتاہ لَگٲوَنہٕ خاطرِ مایکروفون اِجازَت ضَروٗری چھُ۔"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বর খংদোকনবগীদমক মাইক্রোফোন অনুমতি মথৌ তাই।"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱥᱩᱨ ᱪᱤᱱᱦᱟᱹ ᱞᱟᱹᱜᱤᱫ ᱢᱟᱭᱠᱨᱳᱯᱷᱚᱱ ᱟᱱᱩᱢᱚᱛᱤ ᱫᱚᱨᱠᱟᱨ᱾"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "سُر ڳولهڻ لاءِ مائڪروفون اجازت گهربل آهي."
          }
        }
      }
    },
