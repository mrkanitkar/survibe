    "SurVibe needs microphone access to detect the notes you play.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "SurVibe को आपके बजाए नोट्स पहचानने के लिए माइक्रोफ़ोन एक्सेस चाहिए।"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुम्ही वाजवलेले स्वर ओळखण्यासाठी SurVibe ला मायक्रोफोन परवानगी आवश्यक आहे."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি যে স্বরগুলি বাজান তা শনাক্ত করতে SurVibe-এর মাইক্রোফোন অনুমতি প্রয়োজন।"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "તમે વગાડેલા સ્વર શોધવા માટે SurVibe ને માઇક્રોફોન પરવાનગી જરૂરી છે."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਤੁਸੀਂ ਜੋ ਸੁਰਾਂ ਵਜਾਉਂਦੇ ਹੋ ਉਹ ਖੋਜਣ ਲਈ SurVibe ਨੂੰ ਮਾਈਕ੍ਰੋਫ਼ੋਨ ਇਜਾਜ਼ਤ ਚਾਹੀਦੀ ਹੈ।"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ جو سُر بجاتے ہیں انہیں پہچاننے کے لیے SurVibe کو مائیکروفون اجازت چاہیے۔"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "तपाईंले बजाउनुभएका स्वरहरू पहिचान गर्न SurVibe लाई माइक्रोफोन अनुमति चाहिन्छ।"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "আপুনি বজোৱা স্বৰ চিনাক্ত কৰিবলৈ SurVibe ক মাইক্ৰ'ফোন অনুমতি লাগে।"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ଆପଣ ବଜାଉଥିବା ସ୍ୱର ଚିହ୍ନଟ କରିବାକୁ SurVibe କୁ ମାଇକ୍ରୋଫୋନ୍ ଅନୁମତି ଆବଶ୍ୟକ।"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमी वाजयिल्ले स्वर ओळखूंक SurVibe क मायक्रोफोन परवानगी जाय."
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "अहाँ बजाओल स्वर पहचानबाक लेल SurVibe के माइक्रोफोन अनुमति चाही।"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "भवान् यान् स्वरान् वादयति तान् ज्ञातुं SurVibe यन्त्राय ध्वनिग्राहक-अनुज्ञा आवश्यकी।"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "नों बादानाय सुरफोर सिनायनो SurVibe आ माइक्रफन अनुमति गोनां।"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "तुसां जो सुर बजांदे ओ पछानने आस्तै SurVibe गी माइक्रोफोन इजाजत चाहीदी ऐ।"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "تۆہہٕ بَجٲوَنہٕ سُر پَتاہ لَگٲوَنہٕ خاطرِ SurVibe کِس مایکروفون اِجازَت ضَروٗری چھُ۔"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "নহাক থম্বীবা স্বরশীং খংদোকনবগীদমক SurVibe না মাইক্রোফোন অনুমতি মথৌ তাই।"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱟᱢ ᱵᱟᱡᱟᱣ ᱥᱩᱨ ᱠᱚ ᱪᱤᱱᱦᱟᱹ ᱞᱟᱹᱜᱤᱫ SurVibe ᱠᱮ ᱢᱟᱭᱠᱨᱳᱯᱷᱚᱱ ᱟᱱᱩᱢᱚᱛᱤ ᱫᱚᱨᱠᱟᱨ᱾"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "توهان وڄايل سُر ڳولهڻ لاءِ SurVibe کي مائڪروفون اجازت گهربل آهي."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ನೀವು ನುಡಿಸುವ ಸ್ವರಗಳನ್ನು ಗುರುತಿಸಲು SurVibe ಗೆ ಮೈಕ್ರೋಫೋನ್ ಪ್ರವೇಶ ಅಗತ್ಯವಿದೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "നിങ്ങൾ വായിക്കുന്ന സ്വരങ്ങൾ തിരിച്ചറിയാൻ SurVibe ന് മൈക്രോഫോൺ ആക്‌സസ് ആവശ്യമാണ്."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நீங்கள் இசைக்கும் சுரங்களைக் கண்டறிய SurVibe க்கு மைக்ரோஃபோன் அணுகல் தேவை."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీరు వాయించే స్వరాలను గుర్తించడానికి SurVibe కి మైక్రోఫోన్ యాక్సెస్ అవసరం."
          }
        }
      }
    },
    "Tap the mic button to start detecting notes": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नोट्स पहचानना शुरू करने के लिए माइक बटन दबाएं"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर ओळखणे सुरू करण्यासाठी माइक बटण दाबा"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বর শনাক্ত করা শুরু করতে মাইক বোতাম টিপুন"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "સ્વર શોધવાનું શરૂ કરવા માઇક બટન દબાવો"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸੁਰਾਂ ਖੋਜਣਾ ਸ਼ੁਰੂ ਕਰਨ ਲਈ ਮਾਈਕ ਬਟਨ ਦਬਾਓ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سُر پہچاننا شروع کرنے کے لیے مائیک بٹن دبائیں"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर पहिचान सुरु गर्न माइक बटन थिच्नुहोस्"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বৰ চিনাক্ত কৰা আৰম্ভ কৰিবলৈ মাইক বুটাম টিপক"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ସ୍ୱର ଚିହ୍ନଟ ଆରମ୍ଭ କରିବାକୁ ମାଇକ୍ ବଟନ୍ ଦବାନ୍ତୁ"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर ओळखूंक सुरू करूंक माइक बटण दाबात"
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर पहचानब शुरू करबाक लेल माइक बटन दबाउ"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वर-ज्ञापनम् आरब्धुं ध्वनिग्राहक-बटनं स्पृशत"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "सुर सिनायनो जागायनो माइक बटन थुन"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुर पछानना शुरू करने आस्तै माइक बटन दबाओ"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "سُر پَتاہ لَگٲوُن شُروٗع کَرنہٕ خاطرِ مایک بٹن دَبٲوِو"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বর খংদোকপা হৌদোকনবগীদমক মাইক বটন থম্বীরকউ"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱥᱩᱨ ᱪᱤᱱᱦᱟᱹ ᱮᱦᱚᱵ ᱞᱟᱹᱜᱤᱫ ᱢᱟᱭᱠ ᱵᱚᱴᱚᱱ ᱛᱤᱯ ᱢᱮ"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "سُر ڳولهڻ شروع ڪرڻ لاءِ مائڪ بٽڻ دٻايو"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸ್ವರಗಳನ್ನು ಗುರುತಿಸಲು ಪ್ರಾರಂಭಿಸಲು ಮೈಕ್ ಬಟನ್ ಒತ್ತಿ"
