{
  "sourceLanguage": "en",
  "strings": {
    "—": {
      "comment": "A separator between the Western and Swar note names in the active note label.",
      "isCommentAutoGenerated": true
    },
    "%@ %lld, %@": {
      "comment": "A combined label for a note displayed in the Practice tab. The first part shows the Western name and octave of the note, separated by a space. The second part provides the equivalent name in the Indian (Swar) musical system, also separated by a space.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$lld, %3$@"
          }
        }
      }
    },
    "%@, %@": {
      "comment": "A label for each note in the note history, combining its Western and Swar names.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$@"
          }
        }
      }
    },
    "%@%lld": {
      "comment": "A note name displayed in a large, bold font, followed by a hyphen and a smaller note name. The hyphen separates the Western name from the Swar name.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@%2$lld"
          }
        }
      }
    },
    "%@%lld, %@": {
      "comment": "A label describing a piano key, including its letter name and octave.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@%2$lld, %3$@"
          }
        }
      }
    },
    "|%lld": {
      "comment": "A label showing the number of times the pitch detection algorithm has triggered.",
      "isCommentAutoGenerated": true
    },
    "amp: %@": {
      "comment": "A label displaying the current amplitude of the audio input, with an optional count of recent detections. The argument is the string “%.4f”.",
      "isCommentAutoGenerated": true
    },
    "Both": {
      "comment": "Display name for the \"Both\" detection mode in the Pitch Detection settings.",
