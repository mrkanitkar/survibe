    "Lessons and courses coming in Sprint 1": {
      "comment": "A description of the content available in the \"Learn\" tab.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पाठ और कोर्स Sprint 1 में आ रहे हैं"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಪಾಠಗಳು ಮತ್ತು ಕೋರ್ಸ್‌ಗಳು Sprint 1 ರಲ್ಲಿ ಬರಲಿವೆ"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "പാഠങ്ങളും കോഴ്‌സുകളും Sprint 1 ൽ വരുന്നു"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பாடங்களும் படிப்புகளும் Sprint 1 இல் வருகின்றன"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "పాఠాలు మరియు కోర్సులు Sprint 1 లో వస్తున్నాయి"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "धडे आणि अभ्यासक्रम Sprint 1 मध्ये येत आहेत"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পাঠ এবং কোর্স Sprint 1 এ আসছে"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "પાઠ અને અભ્યાસક્રમ Sprint 1 માં આવી રહ્યા છે"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਪਾਠ ਅਤੇ ਕੋਰਸ Sprint 1 ਵਿੱਚ ਆ ਰਹੇ ਹਨ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اسباق اور کورسز Sprint 1 میں آ رہے ہیں"
