        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱢᱟᱭᱠᱨᱳᱯᱷᱚᱱ ᱛᱮ ᱯᱤᱭᱟᱱᱚ ᱥᱩᱨ ᱟᱹᱭᱠᱩᱜ ᱮᱦᱚᱵ ᱮᱫᱟ"
