        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "পাঠ আৰু পাঠ্যক্ৰম Sprint 1 ত আহি আছে"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ପାଠ ଏବଂ କୋର୍ସ Sprint 1 ରେ ଆସୁଛି"
          }
        },
        "kok": {
          "stringUnit": {
