    "SurVibe needs to restart to apply the new language.": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नई भाषा लागू करने के लिए SurVibe को पुनरारंभ करना होगा।"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "नवीन भाषा लागू करण्यासाठी SurVibe पुन्हा सुरू करणे आवश्यक आहे."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নতুন ভাষা প্রয়োগ করতে SurVibe পুনরায় চালু করতে হবে।"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "નવી ભાષા લાગુ કરવા માટે SurVibe ને પુનઃપ્રારંભ કરવું જરૂરી છે."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਨਵੀਂ ਭਾਸ਼ਾ ਲਾਗੂ ਕਰਨ ਲਈ SurVibe ਨੂੰ ਮੁੜ-ਚਾਲੂ ਕਰਨਾ ਪਵੇਗਾ।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "புதிய மொழியைப் பயன்படுத்த SurVibe-ஐ மறுதொடக்கம் செய்ய வேண்டும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "కొత్త భాషను వర్తింపజేయడానికి SurVibe పునఃప్రారంభించాలి."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಹೊಸ ಭಾಷೆಯನ್ನು ಅನ್ವಯಿಸಲು SurVibe ಮರುಪ್ರಾರಂಭಿಸಬೇಕು."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "പുതിയ ഭാഷ ബാധകമാക്കാൻ SurVibe പുനരാരംഭിക്കണം."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نئی زبان لاگو کرنے کے لیے SurVibe کو دوبارہ شروع کرنا ہوگا۔"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "নতুন ভাষা প্ৰয়োগ কৰিবলৈ SurVibe পুনৰাৰম্ভ কৰিব লাগিব।"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ନୂଆ ଭାଷା ପ୍ରୟୋଗ କରିବାକୁ SurVibe ପୁନଃଆରମ୍ଭ କରିବା ଆବଶ୍ୟକ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "नयाँ भाषा लागू गर्न SurVibe पुनःसुरु गर्नुपर्छ।"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "نئين ٻولي لاڳو ڪرڻ لاءِ SurVibe ٻيهر شروع ڪرڻو پوندو."
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "نۆو زَبان لاگوٗ کَرنَس خٲطرٕ SurVibe دوبارٕ شروع کَرُن ضَروری چھُ."
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "नवी भाशा लागू करपाक SurVibe पुनरारंभ करचें पडटलें."
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "नवीन भाषा लागू करबाक लेल SurVibe केँ पुनः आरंभ करबाक पड़त।"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "नवीनां भाषां प्रयोक्तुं SurVibe पुनःप्रारब्धव्यम्।"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "गोदान रावखौ बाहायनो थाखायSurVibe-खौ फिनो सालायनो गोनांगौ।"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "नमीं भाशा लागू करने आस्तै SurVibe दोबारा शुरू करना पौना।"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "অনৌবা লোন শীজিন্নবা তাবদা SurVibe অমুক হৌগতকদবনি।"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱱᱟᱶᱟ ᱯᱟᱹᱨᱥᱤ ᱞᱟᱹᱜᱤᱫ ᱞᱟᱹᱜᱤᱫ SurVibe ᱵᱟᱨ ᱮᱛᱚᱦᱚᱵ ᱞᱟᱹᱠᱛᱤᱭᱟᱹ᱾"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SurVibe needs to restart to apply the new language."
          }
        }
      }
    },
