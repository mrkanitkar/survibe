        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "സ്വരങ്ങൾ തിരിച്ചറിയാൻ തുടങ്ങാൻ മൈക്ക് ബട്ടൺ ടാപ്പ് ചെയ്യുക"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சுரங்களைக் கண்டறியத் தொடங்க மைக் பொத்தானைத் தட்டவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "స్వరాలను గుర్తించడం ప్రారంభించడానికి మైక్ బటన్ నొక్కండి"
          }
        }
      }
