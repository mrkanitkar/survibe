    "Double tap to use system language": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम भाषा उपयोग करने के लिए डबल टैप करें"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम भाषा वापरण्यासाठी दोनदा टॅप करा"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সিস্টেম ভাষা ব্যবহার করতে ডাবল ট্যাপ করুন"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "સિસ્ટમ ભાષા વાપરવા ડબલ ટેપ કરો"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸਿਸਟਮ ਭਾਸ਼ਾ ਵਰਤਣ ਲਈ ਡਬਲ ਟੈਪ ਕਰੋ"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கணினி மொழியைப் பயன்படுத்த இருமுறை தட்டவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "వ్యవస్థ భాషను ఉపయోగించడానికి రెండుసార్లు నొక్కండి"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ವ್ಯವಸ್ಥೆಯ ಭಾಷೆಯನ್ನು ಬಳಸಲು ಎರಡು ಬಾರಿ ಟ್ಯಾಪ್ ಮಾಡಿ"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "സിസ്റ്റം ഭാഷ ഉപയോഗിക്കാൻ ഡബിൾ ടാപ്പ് ചെയ്യുക"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سسٹم زبان استعمال کرنے کے لیے ڈبل ٹیپ کریں"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "ছিষ্টেম ভাষা ব্যৱহাৰ কৰিবলৈ ডাবল টেপ কৰক"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ସିଷ୍ଟମ ଭାଷା ବ୍ୟବହାର କରିବାକୁ ଡବଲ ଟ୍ୟାପ କରନ୍ତୁ"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रणाली भाषा प्रयोग गर्न डबल ट्याप गर्नुहोस्"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "سسٽم ٻولي استعمال ڪرڻ لاءِ ڊبل ٽيپ ڪريو"
          }
        },
        "ks": {
          "stringUnit": {
            "state": "translated",
            "value": "سِسٹَم زَبان اِستعمال کَرنَس خٲطرٕ ڈَبَل ٹیپ کَرِو"
          }
        },
        "kok": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम भाशा वापरपाक दोनदां टॅप करात"
          }
        },
        "mai": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम भाषा उपयोग करबाक लेल डबल टैप करू"
          }
        },
        "sa": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रणालीभाषां प्रयोक्तुं द्विस्पर्शं कुर्वन्तु"
          }
        },
        "brx": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टेम राव बाहायनो थाखाय डबल टेप खालाम"
          }
        },
        "doi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम भाशा इस्तेमाल करने आस्तै डबल टैप करो"
          }
        },
        "mni": {
          "stringUnit": {
            "state": "translated",
            "value": "সিস্তেম লোন শীজিন্নবা তাবদা টু টেপ তৌবীয়ু"
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱥᱤᱥᱴᱮᱢ ᱯᱟᱹᱨᱥᱤ ᱵᱮᱵᱷᱟᱨ ᱞᱟᱹᱜᱤᱫ ᱵᱟᱨ ᱴᱮᱯ ᱢᱮ"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Double tap to use system language"
          }
        }
      }
    },
    "Current language: %@. Double tap to change.": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
